<mjml>
  <mj-head>
    <mj-title>Would you be open to a yard sign?</mj-title>
    <mj-preview>{{COMPANY_NAME}} has one quick question for you</mj-preview>
    <mj-attributes>
      <mj-all font-family="'Helvetica Neue', Helvetica, Arial, sans-serif" color="#1f2933" />
      <mj-body background-color="#eef2eb" />
      <mj-section padding="0" />
      <mj-column padding="0" />
      <mj-text font-size="16px" line-height="1.6" color="#425466" padding="0" />
      <mj-button
        background-color="#2e403d"
        color="#c9dd80"
        font-size="14px"
        font-weight="700"
        inner-padding="16px 28px"
        border-radius="8px"
        padding="0"
      />
    </mj-attributes>
    <mj-style inline="inline">
      .email-shell {
        box-shadow: 0 14px 34px rgba(31, 41, 51, 0.08);
      }

      .eyebrow {
        font-weight: 700;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        color: #3f8a3d;
      }
    </mj-style>
  </mj-head>
  <mj-body>
    <mj-wrapper css-class="email-shell" background-color="#ffffff" padding="28px 16px" border-radius="16px">
      <mj-section background-color="#1f2933">
        <mj-column>
          <mj-image
            src="https://app.pappaslandscaping.com/images/email-logo.png"
            alt="{{COMPANY_NAME}}"
            width="210px"
            align="left"
            padding="18px 28px"
          />
        </mj-column>
      </mj-section>

      <mj-section background-color="#ffffff">
        <mj-column>
          <mj-text
            css-class="eyebrow"
            font-size="12px"
            font-weight="700"
            letter-spacing="0.8px"
            text-transform="uppercase"
            color="#3f8a3d"
            align="left"
            padding="30px 28px 0 28px"
          >
            Quick Question
          </mj-text>
          <mj-text
            font-size="32px"
            line-height="1.2"
            font-weight="800"
            color="#1f2933"
            align="left"
            padding="10px 28px 14px 28px"
          >
            Would you be open to a yard sign?
          </mj-text>
          <mj-text font-size="17px" line-height="1.6" color="#2d3a45" align="left" padding="0 28px">
            Hi {{CUSTOMER_FIRST_NAME}},
          </mj-text>
          <mj-text align="left" padding="12px 28px 0 28px">
            Quick question for you.
          </mj-text>
          <mj-text align="left" padding="12px 28px 0 28px">
            Would you be open to us placing a small yard sign on your property while we service it?
          </mj-text>
          <mj-text align="left" padding="12px 28px 0 28px">
            It helps other local homeowners find us. If you'd rather not, no problem at all.
          </mj-text>
          <mj-text align="left" padding="12px 28px 0 28px">
            Use the options below to let us know.
          </mj-text>
        </mj-column>
      </mj-section>

      <mj-section background-color="#ffffff" padding="24px 28px 0 28px">
        <mj-column>
          <mj-button href="{{YARD_SIGN_YES_LINK}}" align="center">
            Yes, we'd be open to a sign
          </mj-button>
        </mj-column>
      </mj-section>

      <mj-section background-color="#ffffff" padding="14px 28px 0 28px">
        <mj-column>
          <mj-button href="{{YARD_SIGN_NO_LINK}}" align="center">
            No, not at this time
          </mj-button>
        </mj-column>
      </mj-section>

      <mj-section background-color="#ffffff" padding="28px 28px 0 28px">
        <mj-column>
          <mj-divider border-color="#d7dfd1" border-width="1px" />
        </mj-column>
      </mj-section>

      <mj-section background-color="#f7f9f5" padding="20px 28px 24px 28px">
        <mj-column>
          <mj-text font-size="14px" line-height="1.6" color="#5b6773" align="center" padding="0">
            Questions? Call {{COMPANY_PHONE}} or email {{COMPANY_EMAIL}} and we’ll be happy to help.
          </mj-text>
          <mj-text font-size="13px" line-height="1.7" color="#5b6773" padding="16px 0 0 0" align="center">
            {{COMPANY_NAME}}<br />
            {{COMPANY_PHONE}}<br />
            {{COMPANY_EMAIL}}
          </mj-text>
        </mj-column>
      </mj-section>
    </mj-wrapper>
  </mj-body>
</mjml>
