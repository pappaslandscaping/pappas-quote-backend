DATABASE_URL=postgres://user:password@localhost:5432/pappas_quote_backend
# Railway fallback: if DATABASE_URL is omitted, the app/scripts can derive it from PGHOST/PGPORT/PGUSER/PGPASSWORD/PGDATABASE.
# PGHOST=
# PGPORT=
# PGUSER=
# PGPASSWORD=
# PGDATABASE=
JWT_SECRET=replace-with-a-long-random-secret
CRON_SECRET=replace-with-a-long-random-secret

NODE_ENV=development
PORT=3000
BASE_URL=https://app.pappaslandscaping.com
EMAIL_ASSETS_URL=https://app.pappaslandscaping.com
NOTIFICATION_EMAIL=hello@pappaslandscaping.com

# Optional one-time bootstrap only. Leave blank in normal runtime.
BOOTSTRAP_ADMIN_PASSWORD=

# Optional integrations
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SQUARE_ACCESS_TOKEN=
SQUARE_APPLICATION_ID=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_ENVIRONMENT=sandbox
STRIPE_SECRET_KEY=
RESEND_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_ENVIRONMENT=sandbox
QB_REDIRECT_URI=http://localhost:3000/api/quickbooks/callback
GOOGLE_MAPS_API_KEY=
COPILOTCRM_USERNAME=
COPILOTCRM_PASSWORD=
COPILOT_USERNAME=
COPILOT_PASSWORD=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
APP_PASSWORD=

# AI writing surface overrides
AI_WRITING_PROVIDER=openai
AI_WRITING_OPENAI_MODEL=gpt-5.4-mini
AI_WRITING_OPENAI_FALLBACK_MODEL=gpt-5-mini
AI_ANTHROPIC_MODEL=claude-sonnet-4-20250514
