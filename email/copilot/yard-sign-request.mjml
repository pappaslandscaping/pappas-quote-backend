<mjml>
  <mj-head>
    <mj-title>Would you be open to a yard sign?</mj-title>
    <mj-preview>{{COMPANY_NAME}} has one quick question for you</mj-preview>
    <mj-attributes>
      <mj-all font-family="Helvetica, Arial, sans-serif" color="#1f2933" />
      <mj-body background-color="#eef2eb" />
      <mj-section padding="0" />
      <mj-column padding="0" />
      <mj-text font-size="15px" line-height="1.8" color="#425466" padding="0" />
      <mj-button
        background-color="#2e403d"
        color="#c9dd80"
        font-size="14px"
        font-weight="700"
        inner-padding="16px 28px"
        border-radius="999px"
        padding="0"
      />
      <mj-divider border-color="#d7dfd1" border-width="1px" padding="0" />
    </mj-attributes>
    <mj-style inline="inline">
      .email-shell {
        box-shadow: 0 16px 38px rgba(31, 41, 51, 0.08);
      }
    </mj-style>
  </mj-head>
  <mj-body>
    <mj-wrapper background-color="#ffffff" border-radius="22px" css-class="email-shell" padding="28px 16px">
      <mj-section background-color="#1f2933" border-radius="22px 22px 0 0" padding="18px 30px">
        <mj-column>
          <mj-image
            src="https://app.pappaslandscaping.com/images/email-logo.png"
            alt="{{COMPANY_NAME}}"
            width="210px"
            align="left"
            padding="0"
          />
        </mj-column>
      </mj-section>

      <mj-section background-color="#ffffff" padding="34px 34px 0 34px">
        <mj-column>
          <mj-table>
            <tr>
              <td style="background:linear-gradient(135deg,#f7f9f5 0%,#edf3e6 100%);border-radius:22px;padding:30px 30px 28px 30px;text-align:left;">
                <div style="font-family:Helvetica, Arial, sans-serif;font-size:11px;font-weight:700;letter-spacing:1px;line-height:1.6;text-transform:uppercase;color:#6e7f6d;">
                  Quick Question
                </div>
                <div style="font-family:Helvetica, Arial, sans-serif;font-size:34px;font-weight:700;line-height:1.08;color:#2e403d;padding:12px 0 16px 0;max-width:430px;">
                  Would you be open to a yard sign?
                </div>
                <div style="font-family:Helvetica, Arial, sans-serif;font-size:15px;line-height:1.8;color:#425466;max-width:470px;text-align:left;">
                  Hi {{CUSTOMER_FIRST_NAME}},
                </div>
                <div style="font-family:Helvetica, Arial, sans-serif;font-size:15px;line-height:1.8;color:#425466;padding-top:12px;max-width:470px;text-align:left;">
                  Quick question for you.
                </div>
                <div style="font-family:Helvetica, Arial, sans-serif;font-size:15px;line-height:1.8;color:#425466;padding-top:12px;max-width:470px;text-align:left;">
                  Would you be open to us placing a small yard sign on your property while we service it?
                </div>
                <div style="font-family:Helvetica, Arial, sans-serif;font-size:15px;line-height:1.8;color:#425466;padding-top:12px;max-width:470px;text-align:left;">
                  It helps other local homeowners find us. If you'd rather not, no problem at all.
                </div>
                <div style="font-family:Helvetica, Arial, sans-serif;font-size:15px;line-height:1.8;color:#425466;padding-top:12px;max-width:470px;text-align:left;">
                  Use the options below to let us know.
                </div>
              </td>
            </tr>
          </mj-table>
        </mj-column>
      </mj-section>

      <mj-section background-color="#ffffff" padding="22px 34px 0 34px">
        <mj-column>
          <mj-table>
            <tr>
              <td style="vertical-align:top;width:48%;padding-right:18px;">
                <div style="font-family:Helvetica, Arial, sans-serif;font-size:11px;font-weight:700;letter-spacing:0.8px;line-height:1.6;text-transform:uppercase;color:#6e7f6d;">
                  Let Us Know
                </div>
                <div style="font-family:Helvetica, Arial, sans-serif;font-size:14px;line-height:1.75;color:#425466;padding-top:10px;">
                  Choose the option that fits best.
                </div>
              </td>
              <td style="vertical-align:top;width:52%;">
                <div style="border-left:3px solid #c9dd80;padding-left:16px;">
                  <div style="font-family:Helvetica, Arial, sans-serif;font-size:13px;line-height:1.7;color:#2e403d;padding-bottom:10px;">
                    <strong>Yes:</strong> We’d be open to a small yard sign while the property is being serviced.
                  </div>
                  <div style="font-family:Helvetica, Arial, sans-serif;font-size:13px;line-height:1.7;color:#2e403d;">
                    <strong>No:</strong> We’d rather not have a yard sign at this time.
                  </div>
                </div>
              </td>
            </tr>
          </mj-table>
        </mj-column>
      </mj-section>

      <mj-section background-color="#ffffff" padding="28px 34px 0 34px">
        <mj-column>
          <mj-button href="{{YARD_SIGN_YES_LINK}}" align="center">
            Yes, we'd be open to a sign
          </mj-button>
        </mj-column>
      </mj-section>

      <mj-section background-color="#ffffff" padding="14px 34px 4px 34px">
        <mj-column>
          <mj-button href="{{YARD_SIGN_NO_LINK}}" align="center">
            No, not at this time
          </mj-button>
        </mj-column>
      </mj-section>

      <mj-section background-color="#ffffff" padding="26px 28px 0 28px">
        <mj-column>
          <mj-divider border-color="#d7dfd1" border-width="1px" />
        </mj-column>
      </mj-section>

      <mj-section background-color="#f7f9f5" padding="20px 28px 24px 28px">
        <mj-column>
          <mj-text font-size="14px" line-height="1.65" color="#5b6773" align="center" padding="0">
            Questions? Call {{COMPANY_PHONE}} or email {{COMPANY_EMAIL}} and we’ll be happy to help.
          </mj-text>
          <mj-text padding="16px 0 0 0" font-size="0" line-height="0" align="center">
            <a href="https://www.facebook.com/pappaslandscaping" target="_blank" style="display:inline-block;background-color:#2e403d;border-radius:999px;padding:8px;margin-right:10px;">
              <img src="https://app.pappaslandscaping.com/email-assets/fb-white.png" alt="Facebook" width="20" height="20" style="display:block;border:0;outline:none;text-decoration:none;" />
            </a>
            <a href="https://www.instagram.com/pappaslandscaping" target="_blank" style="display:inline-block;background-color:#2e403d;border-radius:999px;padding:8px;">
              <img src="https://app.pappaslandscaping.com/email-assets/ig-white.png" alt="Instagram" width="20" height="20" style="display:block;border:0;outline:none;text-decoration:none;" />
            </a>
          </mj-text>
          <mj-text font-size="13px" line-height="1.7" color="#5b6773" padding="16px 0 0 0" align="center">
            {{COMPANY_NAME}}<br />
            {{COMPANY_PHONE}}<br />
            {{COMPANY_EMAIL}}
          </mj-text>
        </mj-column>
      </mj-section>
    </mj-wrapper>
  </mj-body>
</mjml>
