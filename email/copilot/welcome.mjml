<mjml>
  <mj-head>
    <mj-title>Your customer portal is ready</mj-title>
    <mj-preview>{{COMPANY_NAME}}: your customer portal is ready</mj-preview>
    <mj-attributes>
      <mj-all font-family="'Helvetica Neue', Helvetica, Arial, sans-serif" color="#1f2933" />
      <mj-body background-color="#eef2eb" />
      <mj-section padding="0" />
      <mj-column padding="0" />
      <mj-text padding="0" font-size="16px" line-height="1.6" color="#425466" />
      <mj-button
        background-color="#c9dd80"
        color="#2e403d"
        font-size="14px"
        font-weight="700"
        inner-padding="16px 28px"
        border-radius="8px"
      />
      <mj-divider border-color="#d7dfd1" border-width="1px" padding="0" />
    </mj-attributes>
    <mj-style inline="inline">
      .email-shell {
        box-shadow: 0 14px 34px rgba(31, 41, 51, 0.08);
      }

      .eyebrow {
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        color: #3f8a3d;
      }
    </mj-style>
  </mj-head>
  <mj-body>
    <mj-wrapper background-color="#ffffff" border-radius="16px" css-class="email-shell" padding="28px 16px">
      <mj-section background-color="#1f2933" padding="18px 28px">
        <mj-column>
          <mj-image
            src="https://app.pappaslandscaping.com/images/email-logo.png"
            alt="{{COMPANY_NAME}}"
            width="210px"
            align="left"
            padding="0"
          />
        </mj-column>
      </mj-section>

      <mj-section background-color="#ffffff" padding="30px 28px 10px 28px">
        <mj-column>
          <mj-text css-class="eyebrow">Welcome</mj-text>
          <mj-text font-size="32px" line-height="1.2" font-weight="800" color="#1f2933" padding="10px 0 14px 0">
            Your customer portal is ready
          </mj-text>
          <mj-text font-size="17px" line-height="1.6" color="#2d3a45">
            Hi {{CUSTOMER_FIRST_NAME}},
          </mj-text>
          <mj-text padding="12px 0 0 0">
            Welcome to Pappas &amp; Co. Landscaping. Your customer portal is ready to use anytime.
          </mj-text>
          <mj-text padding="12px 0 0 0">
            To complete your setup, please add a card or bank account on file in your portal.
          </mj-text>
          <mj-text padding="12px 0 0 0">
            You can also use the portal to view invoices, estimates, payment history, and account details in one place.
          </mj-text>
        </mj-column>
      </mj-section>

      <mj-section background-color="#ffffff" padding="20px 28px 0 28px">
        <mj-column background-color="#f7f9f5" border-radius="12px" padding="20px 22px">
          <mj-text font-size="13px" font-weight="700" letter-spacing="0.8px" text-transform="uppercase" color="#5b6773" padding="0 0 12px 0">
            Inside Your Portal
          </mj-text>
          <mj-table>
            <tr>
              <td style="padding:12px 0;border-bottom:1px solid #d7dfd1;font-size:14px;font-weight:700;color:#1f2933;vertical-align:top;">
                Payment Method
              </td>
              <td style="padding:12px 0 12px 18px;border-bottom:1px solid #d7dfd1;font-size:14px;line-height:1.6;color:#425466;vertical-align:top;">
                Add a card or bank account on file to complete your setup
              </td>
            </tr>
            <tr>
              <td style="padding:12px 0;border-bottom:1px solid #d7dfd1;font-size:14px;font-weight:700;color:#1f2933;vertical-align:top;">
                Invoices
              </td>
              <td style="padding:12px 0 12px 18px;border-bottom:1px solid #d7dfd1;font-size:14px;line-height:1.6;color:#425466;vertical-align:top;">
                View balances and payment activity
              </td>
            </tr>
            <tr>
              <td style="padding:12px 0;border-bottom:1px solid #d7dfd1;font-size:14px;font-weight:700;color:#1f2933;vertical-align:top;">
                Estimates
              </td>
              <td style="padding:12px 0 12px 18px;border-bottom:1px solid #d7dfd1;font-size:14px;line-height:1.6;color:#425466;vertical-align:top;">
                Review estimates and approvals
              </td>
            </tr>
            <tr>
              <td style="padding:12px 0;font-size:14px;font-weight:700;color:#1f2933;vertical-align:top;">
                Work Requests
              </td>
              <td style="padding:12px 0 12px 18px;font-size:14px;line-height:1.6;color:#425466;vertical-align:top;">
                Submit a new request anytime
              </td>
            </tr>
          </mj-table>
        </mj-column>
      </mj-section>

      <mj-section background-color="#ffffff" padding="24px 28px 6px 28px">
        <mj-column>
          <mj-button href="{{CUSTOMER_PORTAL_LINK}}" align="center">
            Open Customer Portal
          </mj-button>
        </mj-column>
      </mj-section>

      <mj-section background-color="#ffffff" padding="28px 28px 0 28px">
        <mj-column>
          <mj-divider border-color="#d7dfd1" border-width="1px" />
        </mj-column>
      </mj-section>

      <mj-section background-color="#f7f9f5" padding="20px 28px 24px 28px">
        <mj-column>
          <mj-text font-size="14px" line-height="1.6" color="#5b6773" padding="0">
            Questions? Call {{COMPANY_PHONE}} or email {{COMPANY_EMAIL}} and we’ll be happy to help.
          </mj-text>
          <mj-text padding="16px 0 0 0" font-size="0" line-height="0">
            <a href="https://www.facebook.com/pappaslandscaping" target="_blank" style="display:inline-block;background-color:#c9dd80;border-radius:999px;padding:8px;margin-right:10px;">
              <img src="https://app.pappaslandscaping.com/images/icon-facebook.png" alt="Facebook" width="20" height="20" style="display:block;border:0;outline:none;text-decoration:none;" />
            </a>
            <a href="https://www.instagram.com/pappaslandscaping" target="_blank" style="display:inline-block;background-color:#c9dd80;border-radius:999px;padding:8px;">
              <img src="https://app.pappaslandscaping.com/images/icon-instagram.png" alt="Instagram" width="20" height="20" style="display:block;border:0;outline:none;text-decoration:none;" />
            </a>
          </mj-text>
          <mj-text font-size="13px" line-height="1.7" color="#5b6773" padding="16px 0 0 0">
            {{COMPANY_NAME}}<br />
            {{COMPANY_PHONE}}<br />
            {{COMPANY_EMAIL}}
          </mj-text>
        </mj-column>
      </mj-section>
    </mj-wrapper>
  </mj-body>
</mjml>
