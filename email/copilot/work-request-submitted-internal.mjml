<mjml>
  <mj-head>
    <mj-title>New Work Request Submitted</mj-title>
    <mj-preview>{{CUSTOMER_NAME}} submitted a new work request</mj-preview>
    <mj-attributes>
      <mj-all font-family="'Helvetica Neue', Helvetica, Arial, sans-serif" color="#1f2933" />
      <mj-body background-color="#eef2eb" />
      <mj-section padding="0" />
      <mj-column padding="0" />
      <mj-text font-size="16px" line-height="1.6" color="#425466" padding="0" />
      <mj-divider border-color="#d7dfd1" border-width="1px" padding="0" />
    </mj-attributes>
    <mj-style inline="inline">
      .email-shell {
        box-shadow: 0 14px 34px rgba(31, 41, 51, 0.08);
      }

      .eyebrow {
        font-weight: 700;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        color: #3f8a3d;
      }
    </mj-style>
  </mj-head>
  <mj-body>
    <mj-wrapper css-class="email-shell" background-color="#ffffff" padding="28px 16px" border-radius="16px">
      <mj-section background-color="#1f2933">
        <mj-column>
          <mj-image
            src="https://app.pappaslandscaping.com/images/email-logo.png"
            alt="{{COMPANY_NAME}}"
            width="210px"
            align="left"
            padding="18px 28px"
          />
        </mj-column>
      </mj-section>

      <mj-section background-color="#ffffff">
        <mj-column>
          <mj-text
            css-class="eyebrow"
            font-size="12px"
            font-weight="700"
            letter-spacing="0.8px"
            text-transform="uppercase"
            color="#3f8a3d"
            padding="30px 28px 0 28px"
          >
            Internal Notification
          </mj-text>
          <mj-text
            font-size="32px"
            line-height="1.2"
            font-weight="800"
            color="#1f2933"
            padding="10px 28px 14px 28px"
          >
            New Work Request Submitted
          </mj-text>
          <mj-text padding="0 28px">
            {{CUSTOMER_NAME}} submitted a new work request.
          </mj-text>
        </mj-column>
      </mj-section>

      <mj-section background-color="#ffffff" padding="18px 28px 0 28px">
        <mj-column background-color="#f7f9f5" border="1px solid #d7dfd1" border-radius="12px" padding="18px 20px">
          <mj-text
            font-size="13px"
            font-weight="700"
            letter-spacing="0.8px"
            text-transform="uppercase"
            color="#5b6773"
            padding="0 0 12px 0"
          >
            Next Steps
          </mj-text>
          <mj-table padding="0">
            <tr>
              <td style="padding:12px 0;border-bottom:1px solid #d7dfd1;font-family:'Helvetica Neue', Helvetica, Arial, sans-serif;font-size:14px;font-weight:700;color:#1f2933;vertical-align:top;">Review</td>
              <td style="padding:12px 0 12px 18px;border-bottom:1px solid #d7dfd1;font-family:'Helvetica Neue', Helvetica, Arial, sans-serif;font-size:14px;line-height:1.6;color:#425466;vertical-align:top;">Review {{CUSTOMER_FIRST_NAME}}'s work request in Copilot</td>
            </tr>
            <tr>
              <td style="padding:12px 0;border-bottom:1px solid #d7dfd1;font-family:'Helvetica Neue', Helvetica, Arial, sans-serif;font-size:14px;font-weight:700;color:#1f2933;vertical-align:top;">Pricing</td>
              <td style="padding:12px 0 12px 18px;border-bottom:1px solid #d7dfd1;font-family:'Helvetica Neue', Helvetica, Arial, sans-serif;font-size:14px;line-height:1.6;color:#425466;vertical-align:top;">Prepare pricing or an estimate if needed</td>
            </tr>
            <tr>
              <td style="padding:12px 0;font-family:'Helvetica Neue', Helvetica, Arial, sans-serif;font-size:14px;font-weight:700;color:#1f2933;vertical-align:top;">Follow Up</td>
              <td style="padding:12px 0 12px 18px;font-family:'Helvetica Neue', Helvetica, Arial, sans-serif;font-size:14px;line-height:1.6;color:#425466;vertical-align:top;">Follow up with {{CUSTOMER_FIRST_NAME}}</td>
            </tr>
          </mj-table>
        </mj-column>
      </mj-section>

      <mj-section background-color="#ffffff" padding="28px 28px 0 28px">
        <mj-column>
          <mj-divider border-color="#d7dfd1" border-width="1px" />
        </mj-column>
      </mj-section>

      <mj-section background-color="#f7f9f5" padding="20px 28px 24px 28px">
        <mj-column>
          <mj-text font-size="14px" line-height="1.6" color="#5b6773" padding="0" align="center">
            Internal notification from {{COMPANY_NAME}}
          </mj-text>
        </mj-column>
      </mj-section>
    </mj-wrapper>
  </mj-body>
</mjml>
